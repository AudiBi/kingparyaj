# ============================================
# .env.example - Configuration template
# Copier ce fichier vers .env et modifier les valeurs
# NE PAS COMMITER .env !
# ============================================

# ------------------- APPLICATION -------------------
APP_NAME=Parier Keno & Lucky
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ------------------- BASE DE DONNÉES -------------------
# Format: postgresql+asyncpg://user:password@host:port/database
# Pour les caractères spéciaux dans le mot de passe: @=%40, #=%23, !=%21
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@127.0.0.1:5432/parier_keno

# Pool de connexions
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ------------------- REDIS -------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ------------------- SÉCURITÉ -------------------
# Générer une clé avec: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-use-a-very-long-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ------------------- CORS -------------------
# Liste des origines autorisées, séparées par des virgules
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8501

# ------------------- MONCASH (Digicel Haïti) -------------------
MONCASH_ENABLED=false
MONCASH_API_URL=https://api.moncash.digicelhaiti.com/v1
MONCASH_MERCHANT_ID=
MONCASH_API_KEY=
MONCASH_API_SECRET=
MONCASH_WEBHOOK_SECRET=

# ------------------- NATCASH (NatCom Haïti) -------------------
NATCASH_ENABLED=false
NATCASH_API_URL=https://api.natcash.natcom.ht/v1
NATCASH_MERCHANT_ID=
NATCASH_API_KEY=
NATCASH_WEBHOOK_SECRET=

# ------------------- SMS (Twilio) -------------------
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+509XXXXXXXX

# ------------------- EMAIL -------------------
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@parierkeno.ht

# ------------------- LIMITES JEU -------------------
# Keno
KENO_MIN_BET=10
KENO_MAX_BET=100000
KENO_MIN_PICKS=1
KENO_MAX_PICKS=10
KENO_DRAW_INTERVAL_MINUTES=5

# Lucky Wheel
LUCKY_WHEEL_MIN_BET=10
LUCKY_WHEEL_MAX_BET=10000

# ------------------- LIMITES JOUEUR -------------------
MAX_DAILY_DEPOSIT=500000
MAX_DAILY_LOSS=100000
MAX_SINGLE_BET=100000

# ------------------- RATE LIMITING -------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# ------------------- LOGGING -------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ------------------- LEH (Loterie de l'État Haïtien) -------------------
LEH_ENABLED=false
LEH_API_URL=https://api.leh.ht/v1
LEH_API_KEY=

# ------------------- MAINTENANCE -------------------
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Le site est en maintenance. Revenez bientôt !